{
  "info": {
    "name": "E-Commerce Node API",
    "description": "Complete Postman collection for the Node.js E-Commerce API. Covers Health, Auth, Products, Categories, Cart, Wishlist, Orders, Reviews, Notifications, and Admin modules.\n\n**Setup:**\n1. Import this collection\n2. Import `ecommerce-api.postman_environment.json`\n3. Select the environment\n4. Run **Auth / Register Customer** or **Auth / Login** — tokens are saved automatically\n5. All authenticated requests use `{{accessToken}}` automatically",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health",
            "description": "Returns server status, uptime, and environment"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('status is ok', () => {",
                  "  const d = pm.response.json();",
                  "  pm.expect(d.data.status).to.eql('ok');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Customer",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@ecommerce.com\",\n  \"password\": \"Password@123\",\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Doe\"\n}"
            },
            "description": "Register a new customer. Tokens are saved automatically to environment variables."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('returns tokens', () => {",
                  "  const d = pm.response.json();",
                  "  pm.expect(d.success).to.be.true;",
                  "  pm.expect(d.data.tokens.accessToken).to.be.a('string');",
                  "  pm.environment.set('accessToken', d.data.tokens.accessToken);",
                  "  pm.environment.set('refreshToken', d.data.tokens.refreshToken);",
                  "  pm.environment.set('userId', d.data.user._id);",
                  "  console.log('Saved customer tokens');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Register Customer — Duplicate Email (expect 409)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@ecommerce.com\",\n  \"password\": \"Password@123\",\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Doe\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 409', () => pm.response.to.have.status(409));",
                  "pm.test('correct error message', () => {",
                  "  pm.expect(pm.response.json().message).to.include('Email');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Register Customer — Weak Password (expect 400)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newuser@ecommerce.com\",\n  \"password\": \"weak\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('validation errors present', () => {",
                  "  const d = pm.response.json();",
                  "  pm.expect(d.errors.length).to.be.greaterThan(0);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Register Seller",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/register/seller",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"seller@ecommerce.com\",\n  \"password\": \"Password@123\",\n  \"firstName\": \"Bob\",\n  \"lastName\": \"Seller\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('role is seller', () => {",
                  "  pm.expect(pm.response.json().data.user.role).to.eql('seller');",
                  "  pm.environment.set('sellerToken', pm.response.json().data.tokens.accessToken);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@ecommerce.com\",\n  \"password\": \"Password@123\"\n}"
            },
            "description": "Login as customer. Tokens are saved automatically."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('returns access and refresh tokens', () => {",
                  "  const d = pm.response.json();",
                  "  pm.expect(d.data.tokens.accessToken).to.be.a('string');",
                  "  pm.expect(d.data.tokens.refreshToken).to.be.a('string');",
                  "  pm.environment.set('accessToken', d.data.tokens.accessToken);",
                  "  pm.environment.set('refreshToken', d.data.tokens.refreshToken);",
                  "  pm.environment.set('userId', d.data.user._id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login — Wrong Password (expect 401)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@ecommerce.com\",\n  \"password\": \"WrongPass@999\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        },
        {
          "name": "Login as Admin",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@ecommerce.com\",\n  \"password\": \"Password@123\"\n}"
            },
            "description": "Login as admin (requires seed data from Phase 10)"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const d = pm.response.json();",
                  "if (d.success) {",
                  "  pm.environment.set('adminToken', d.data.tokens.accessToken);",
                  "  console.log('Admin token saved');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login as Seller",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"seller@ecommerce.com\",\n  \"password\": \"Password@123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const d = pm.response.json();",
                  "if (d.success) pm.environment.set('sellerToken', d.data.tokens.accessToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/refresh-token",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('returns new accessToken', () => {",
                  "  const d = pm.response.json();",
                  "  pm.expect(d.data.accessToken).to.be.a('string');",
                  "  pm.environment.set('accessToken', d.data.accessToken);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/change-password",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"Password@123\",\n  \"newPassword\": \"NewPass@456\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/logout",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.environment.unset('accessToken');",
                  "pm.environment.unset('refreshToken');",
                  "console.log('Tokens cleared from environment');"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout — No Token (expect 401)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/logout"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/products",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const d = pm.response.json();",
                  "if (d.success && d.data.items && d.data.items.length > 0) {",
                  "  pm.environment.set('productId', d.data.items[0]._id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Search Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/products?search=phone&page=1&pageSize=5",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products"],
              "query": [
                { "key": "search", "value": "phone" },
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "5" }
              ]
            }
          }
        },
        {
          "name": "Filter by Price Range",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/products?minPrice=100&maxPrice=500&sortBy=price&sortOrder=asc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products"],
              "query": [
                { "key": "minPrice", "value": "100" },
                { "key": "maxPrice", "value": "500" },
                { "key": "sortBy", "value": "price" },
                { "key": "sortOrder", "value": "asc" }
              ]
            }
          }
        },
        {
          "name": "Filter by Category",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/products?categoryId={{categoryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products"],
              "query": [
                { "key": "categoryId", "value": "{{categoryId}}" }
              ]
            }
          }
        },
        {
          "name": "Get Featured Products",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/products/featured"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/products/{{productId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Related Products",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/products/{{productId}}/related"
          }
        },
        {
          "name": "Get Product — Invalid ID (expect 400)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/products/not-a-valid-id"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Product (Admin/Seller)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/products",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Smartphone X\",\n  \"sku\": \"PHONE-X-001\",\n  \"description\": \"A high-end smartphone with excellent camera\",\n  \"price\": 799.99,\n  \"salePrice\": 699.99,\n  \"stockQty\": 100,\n  \"categoryId\": \"{{categoryId}}\",\n  \"images\": [],\n  \"tags\": [\"smartphone\", \"electronics\"]\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const d = pm.response.json();",
                  "if (d.success) pm.environment.set('productId', d.data._id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Product — No Auth (expect 401)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/products",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Unauthorized Product\",\n  \"sku\": \"UNAUTH-001\",\n  \"price\": 99,\n  \"categoryId\": \"{{categoryId}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Product — Customer Token (expect 403)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/products",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Forbidden Product\",\n  \"sku\": \"FORBIDDEN-001\",\n  \"price\": 99,\n  \"categoryId\": \"{{categoryId}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 403', () => pm.response.to.have.status(403));"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Product (Admin/Seller)",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/products/{{productId}}",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 749.99,\n  \"stockQty\": 80\n}"
            }
          }
        },
        {
          "name": "Delete Product (Soft Delete)",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/products/{{productId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/categories"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const d = pm.response.json();",
                  "if (d.success && d.data && d.data.length > 0) {",
                  "  pm.environment.set('categoryId', d.data[0]._id);",
                  "  console.log('Saved categoryId:', d.data[0]._id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Category by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/categories/{{categoryId}}"
          }
        },
        {
          "name": "Get Subcategories",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/categories/{{categoryId}}/subcategories"
          }
        },
        {
          "name": "Create Category (Admin)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/categories",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Electronics\",\n  \"description\": \"Electronic gadgets and devices\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const d = pm.response.json();",
                  "if (d.success) pm.environment.set('categoryId', d.data._id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Subcategory (Admin)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/categories",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Smartphones\",\n  \"description\": \"Mobile phones and accessories\",\n  \"parentId\": \"{{categoryId}}\"\n}"
            }
          }
        },
        {
          "name": "Update Category (Admin)",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/categories/{{categoryId}}",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Updated description for electronics\"\n}"
            }
          }
        },
        {
          "name": "Delete Category (Admin)",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/categories/{{categoryId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200 or 400', () => {",
                  "  pm.expect([200, 400]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Cart",
      "item": [
        {
          "name": "Get Cart",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/cart",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Cart Total",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/cart/total",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ]
          }
        },
        {
          "name": "Add Item to Cart",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/cart/items",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"quantity\": 2\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 or 201', () => {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Add Same Item Again (should accumulate)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/cart/items",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"quantity\": 1\n}"
            }
          }
        },
        {
          "name": "Update Cart Item Quantity",
          "request": {
            "method": "PUT",
